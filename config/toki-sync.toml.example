# toki-sync server configuration
# Copy to config/toki-sync.toml and adjust as needed.
# Environment variables are expanded: ${VAR_NAME} → env value (empty if unset).

[server]
# bind = "0.0.0.0"
tcp_port = 9090
http_port = 9091
# external_url = "https://myserver.duckdns.org"  # For JWT issuer + OIDC redirects

[auth]
jwt_secret = "${JWT_SECRET}"
# access_token_ttl_secs = 3600       # 1 hour
# refresh_token_ttl_secs = 7776000   # 90 days
# registration_mode = "closed"       # "open" | "approval" | "closed"

[storage]
sqlite_path = "/data/toki_sync.db"

[events]
# backend = "fjall"                  # Default: embedded, no external dependencies
# fjall_path = "/data/events.fjall"
# backend = "clickhouse"             # Optional: external ClickHouse
# clickhouse_url = "http://clickhouse:8123"

[log]
level = "info"
# json = true                        # JSON log format (for log aggregators)
