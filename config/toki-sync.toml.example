# toki-sync server configuration
# Copy to config/toki-sync.toml and adjust as needed.
# Environment variables are expanded: ${VAR_NAME} → env value (empty if unset).

[server]
# bind = "0.0.0.0"
tcp_port = 9090
http_port = 9091

[auth]
jwt_secret = "${JWT_SECRET}"
# access_token_ttl_secs = 3600       # 1 hour
# refresh_token_ttl_secs = 2592000   # 30 days
# brute_force_max_attempts = 5
# brute_force_window_secs = 300      # 5 minutes
# brute_force_lockout_secs = 900     # 15 minutes
# allow_registration = false

[storage]
db_path = "/data/toki_sync.db"

[backend]
vm_url = "http://victoriametrics:8428"

[log]
level = "info"
json = true
