# toki-sync environment variables
# Copy to .env and fill in your values.
# Never commit .env to version control.

# Admin account password (created on first start)
TOKI_ADMIN_PASSWORD=changeme

# JWT signing secret — generate with: openssl rand -hex 32
TOKI_JWT_SECRET=replace-with-64-char-random-hex-string

# Public domain name for HTTPS (used by Caddy)
# Example: sync.example.com or myname.duckdns.org
TOKI_DOMAIN=sync.example.com

# DuckDNS token for automatic TLS certificates (caddy-dns/duckdns)
# Leave empty if using a different DNS provider or manual TLS
DUCKDNS_TOKEN=

# Image version tag (default: latest)
TOKI_VERSION=latest
