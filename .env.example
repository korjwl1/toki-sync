# toki-sync environment variables
# Copy to .env and fill in your values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Admin account password (created automatically on first server start).
# Used for the initial admin account (created on first server start).
TOKI_ADMIN_PASSWORD=your-strong-password

# JWT signing secret for authentication tokens.
# Generate a secure random value:
#   openssl rand -base64 32
JWT_SECRET=

# Public URL for the server (used for JWT issuer claim and OIDC redirects).
# Must match your actual domain or IP.
# Examples:
#   https://myserver.duckdns.org   (Scenario A: Caddy + DuckDNS)
#   https://sync.example.com       (Scenario B: existing reverse proxy)
#   https://192.168.1.100           (Scenario C: self-signed TLS)
#   http://localhost:9091           (Scenario D: local development)
TOKI_EXTERNAL_URL=https://yourserver.duckdns.org

# ── Required for Caddy TLS (--profile caddy only) ────────────────────────────

# DuckDNS API token for automatic TLS certificates via Let's Encrypt DNS challenge.
#
# How to get your token:
#   1. Go to https://www.duckdns.org and sign in
#   2. Create a subdomain (e.g., "myserver" -> myserver.duckdns.org)
#   3. Point the subdomain to your server's public IP
#   4. Copy the token displayed at the top of the page
#
# The token looks like: a1b2c3d4-e5f6-7890-abcd-ef1234567890
#
# If your server has a dynamic IP, set up auto-update:
#   crontab: */5 * * * * curl -s "https://www.duckdns.org/update?domains=myserver&token=YOUR_TOKEN&ip=" > /dev/null
#   or Docker: docker run -d --name duckdns-updater -e SUBDOMAINS=myserver -e TOKEN=YOUR_TOKEN lscr.io/linuxserver/duckdns:latest
DUCKDNS_TOKEN=your-duckdns-token

# ── IP-only deployment (self-signed TLS) ─────────────────────────────────────
# For servers without a domain name (Scenario C):
#   - Set TOKI_EXTERNAL_URL to https://<your-ip>
#   - Leave DUCKDNS_TOKEN empty or remove it
#   - Client connects with: toki sync enable --server <ip> --insecure

# ── Optional ──────────────────────────────────────────────────────────────────

# Docker image version tag (default: latest).
# Pin to a specific version for reproducible deployments.
TOKI_VERSION=0.1.0
