# toki-sync environment variables
# Copy to .env and fill in your values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Admin account password (created on first start)
TOKI_ADMIN_PASSWORD=your-strong-password

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=

# Public URL for the server
TOKI_EXTERNAL_URL=https://yourserver.duckdns.org

# ── Required for Caddy TLS (--profile caddy only) ────────────────────────────

# DuckDNS token for automatic TLS certificates (Let's Encrypt DNS challenge)
DUCKDNS_TOKEN=your-duckdns-token

# ── IP-only deployment (self-signed TLS) ─────────────────────────────────────
# Leave TOKI_EXTERNAL_URL and DUCKDNS_TOKEN empty.
# Client: toki sync enable --server <ip>:9090 --insecure --username admin

# ── Optional ──────────────────────────────────────────────────────────────────

# Image version tag (default: latest)
TOKI_VERSION=0.1.0
